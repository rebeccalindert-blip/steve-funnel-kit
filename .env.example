# GoHighLevel CRM (required for lead capture forms)
GHL_API_KEY=your-ghl-api-key-here
GHL_LOCATION_ID=your-ghl-location-id-here

# Your live domain (used for SEO and CORS security)
SITE_URL=https://yourdomain.com

# Analytics (optional)
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Maps (optional — only if using GoogleMap component)
# PUBLIC_GOOGLE_MAPS_API_KEY=your-key-here

# Cookie consent banner (optional)
# PUBLIC_CONSENT_ENABLED=true
# PUBLIC_PRIVACY_POLICY_URL=https://yourdomain.com/terms

# SEO verification (optional)
# GOOGLE_SITE_VERIFICATION=your-verification-code
# BING_SITE_VERIFICATION=your-verification-code

# Demo mode — enables the theme customizer widget (leave disabled for production)
# PUBLIC_DEMO_MODE=true
