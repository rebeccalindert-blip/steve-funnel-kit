---
/**
 * Lead Magnet / Squeeze Page — with Form
 * Clean, scrollable layout. Vertically centered hero on tall screens.
 * Responsive: mobile (default), tablet (md:), desktop (lg:). Light + dark mode.
 *
 * Mobile/Tablet: single column stacked
 * Desktop: two-column — text + form left, product mockup right
 */
import '@/styles/global.css';
import SEO from '@/components/seo/SEO.astro';
import Logo from '@/components/ui/marketing/Logo/Logo.astro';
import LeadCaptureForm from '@/components/forms/LeadCaptureForm.tsx';
import siteConfig from '@/config/site.config';

const formTags = ['funnel_blueprint', 'lead_magnet'];

const termsHtml = `<p>By providing my information, I agree to receive communications and accept the <a href="/terms">Privacy Policy</a>. Unsubscribe anytime.</p>`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={siteConfig.branding.favicon.svg} />
    <SEO
      title="The $100K Funnel Blueprint — Free Download"
      description="Everything you need to build automated funnels that convert cold traffic into paying customers. Proven templates, automation sequences, and step-by-step playbooks."
    />
    <script is:inline>
      (function () {
        var mq = window.matchMedia('(prefers-color-scheme: dark)');
        function apply() { document.documentElement.classList.toggle('dark', mq.matches); }
        apply();
        mq.addEventListener('change', apply);
      })();
    </script>
  </head>

  <body class="min-h-dvh flex flex-col bg-background text-foreground antialiased">

    {/* ── Logo ── */}
    <header class="shrink-0 py-6">
      <div class="mx-auto max-w-6xl px-6">
        <a href="/">
          <Logo variant="full" size="lg" />
        </a>
      </div>
    </header>

    {/* ── Hero ── */}
    <main class="flex-1 flex items-center py-4 md:py-6 lg:py-8">
      <div class="w-full max-w-6xl mx-auto">
        <div class="flex flex-col lg:flex-row lg:items-center lg:gap-16 xl:gap-24">

          {/* ── Text + Form Column ── */}
          <div class="lg:flex-1 lg:max-w-xl">
            <p class="font-mono text-xs md:text-sm font-semibold text-brand-500 uppercase tracking-widest">
              Free Resource
            </p>
            <h1 class="mt-3 md:mt-4 text-3xl md:text-4xl lg:text-5xl xl:text-[3.5rem] font-bold tracking-tight text-foreground leading-[1.1]">
              The $100K Funnel Blueprint
            </h1>
            <p class="mt-3 md:mt-4 text-base md:text-lg text-foreground-muted max-w-lg leading-relaxed">
              Everything you need to build automated funnels that convert cold traffic
              into paying customers.
            </p>

            {/* ── Lead Capture Form ── */}
            <div class="mt-8 md:mt-10">
              <LeadCaptureForm
                client:load
                formTags={formTags}
                submitLabel="Get Instant Access"
                termsHtml={termsHtml}
              />
            </div>

            {/* ── Trust ── */}
            <div class="mt-6 flex items-center justify-center gap-2 text-xs md:text-sm text-foreground-muted">
              <div class="flex gap-0.5">
                {[1,2,3,4,5].map(() => (
                  <svg class="h-4 w-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <span class="uppercase tracking-wider font-medium">Trusted by 10,000+ businesses</span>
            </div>
          </div>

          {/* ── Product Mockup + Benefits ── */}
          <div class="mt-10 lg:mt-0 lg:flex-1 flex flex-col items-center lg:items-end">
            <img
              src="/images/product-mockup.webp"
              alt="The $100K Funnel Blueprint — ebook bundle mockup"
              width="1173"
              height="1410"
              class="w-full max-w-[340px] md:max-w-[400px] lg:max-w-[460px] xl:max-w-[500px] h-auto drop-shadow-2xl"
            />
            <ul class="mt-6 space-y-2.5">
              {[
                'Proven templates that generated $12M+ in revenue',
                'Step-by-step automation sequences included',
                'Works for coaches, agencies, and SaaS founders',
              ].map((benefit) => (
                <li class="flex items-start gap-2.5 text-sm text-foreground-secondary">
                  <svg class="h-5 w-5 mt-0.5 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>{benefit}</span>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </main>

    {/* ── Footer ── */}
    <footer class="shrink-0 px-6 py-2 border-t border-border">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-2 text-xs md:text-sm text-foreground-muted">
        <p>&copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</p>
        <div class="flex items-center gap-4 md:gap-6">
          <a href="/terms" class="transition-colors hover:text-foreground">Privacy</a>
          <a href="/terms" class="transition-colors hover:text-foreground">Terms of Service</a>
        </div>
      </div>
    </footer>

  </body>
</html>
