---
/**
 * Multi-Step Form — Step 1
 * Basic lead capture (name, email, phone) → redirects to step 2
 * URL: /form
 *
 * Customise: Change the headline, description, benefits, and formTags.
 * The successRedirect sends users to step 2 with their email in the URL.
 */
import LeadLayout from '@/layouts/LeadLayout.astro';
import LeadCaptureForm from '@/components/forms/LeadCaptureForm.tsx';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

const formTags = ['website_lead', 'form_qualify'];

const benefits = [
  'Free strategy session with a real human',
  'Custom action plan for your business',
  'No obligations, no credit card required',
];
---

<LeadLayout
  title="Get Started — Tell Us About Yourself"
  description="Step 1 of 2. Share your details and we'll prepare a custom plan for you."
>
  <section class="sq-hero relative overflow-hidden">
    <div class="bg-grid-pattern pointer-events-none absolute inset-0 [mask-image:linear-gradient(to_bottom,white,transparent)] opacity-40" aria-hidden="true" />

    <div class="mx-auto max-w-6xl px-6 relative z-10 py-6 md:py-0">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-[var(--space-section-gap)] items-center">

        {/* Left Column */}
        <div class="hidden lg:block">
          <div class="mb-6 overflow-hidden rounded-lg">
            <img src="/images/product-mockup.webp" alt="Product preview" class="w-full max-w-xs h-auto" loading="eager" />
          </div>
          <p class="text-xs font-bold text-brand-500 uppercase tracking-wider mb-3">Step 1 of 2</p>
          <h2 class="font-display text-2xl font-bold tracking-tight text-foreground mb-4">What you'll get</h2>
          <ul class="space-y-3">
            {benefits.map((item) => (
              <li class="flex gap-3 items-start text-foreground-secondary text-sm">
                <Icon name="check-circle" size="sm" class="text-brand-500 mt-0.5 shrink-0" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        {/* Right Column: Form */}
        <div>
          <Badge variant="brand" pill>
            <Icon name="user" size="xs" />
            Step 1 of 2
          </Badge>

          <h1 class="mt-3 font-display text-2xl md:text-3xl font-bold tracking-tight text-foreground leading-tight">
            Let's get started.
          </h1>

          <p class="mt-2 text-base leading-relaxed text-foreground-muted">
            Enter your details below. Step 2 takes 30 seconds.
          </p>

          {/* Mobile benefits */}
          <ul class="mt-4 space-y-2 lg:hidden">
            {benefits.map((item) => (
              <li class="flex gap-2 items-start text-foreground-secondary text-sm">
                <Icon name="check" size="sm" class="text-brand-500 mt-0.5 shrink-0" />
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <LeadCaptureForm
            client:load
            formTags={formTags}
            submitLabel="Continue →"
            successRedirect="/form/step-2"
          />
        </div>

      </div>
    </div>
  </section>
</LeadLayout>

<style>
  .sq-hero {
    padding-top: calc(var(--space-page-top-sm) + 32px);
  }
  @media (min-width: 1024px) {
    .sq-hero {
      padding-top: calc(var(--space-page-top-sm) + 64px);
    }
  }
</style>
