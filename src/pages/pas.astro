---
/**
 * PAS (Problem > Agitate > Solution) Long-form Sales Page
 * Layout reference: Programs Page@2x.pdf
 * Uses the component system + Tailwind utilities
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Hero from '@/components/hero/Hero.astro';
import CTA from '@/components/ui/marketing/CTA/CTA.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Accordion from '@/components/ui/overlay/Accordion/Accordion.astro';
import StatCard from '@/components/patterns/StatCard.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import LeadCaptureForm from '@/components/forms/LeadCaptureForm.tsx';
import MobileFormSheet from '@/components/forms/MobileFormSheet.tsx';
import siteConfig from '@/config/site.config';

const formTags = ['funnel_blueprint', 'pas_page'];
const termsHtml = `<p>By providing my information, I agree to receive communications and accept the <a href="/terms">Privacy Policy</a>. Unsubscribe anytime.</p>`;

const faqItems = [
  { title: 'How quickly will I see results?', content: 'Most clients see measurable improvements within 30 days. By day 90, you\'ll have a fully operational sales engine generating leads and revenue on autopilot.' },
  { title: 'What if I already have a website?', content: 'No problem. We audit your current setup and either optimise what you have or build fresh — whichever drives more revenue faster. Either way, you keep full ownership.' },
  { title: 'Is there a money-back guarantee?', content: 'Absolutely. If you\'re not completely satisfied within 30 days, we\'ll refund every cent. No hoops, no questions, no fine print.' },
  { title: 'Do I need technical skills?', content: 'Zero. We handle the tech — CRM, automations, funnels, integrations. You focus on closing deals and serving clients.' },
];
---

<BaseLayout
  title="Growth Mode — Build Your Sales Engine in 90 Days"
  description="Go into Growth Mode with an expert-led program, tutorials, templates and tech. Everything you need to scale revenue."
>
  {/* ── Nav ── */}
  <Header slot="header" layout="minimal" position="fixed" variant="solid" size="lg" />

  {/* ═══════════════════════════════════════════════════
      HERO — Dark background, split layout
  ═══════════════════════════════════════════════════ */}
  <Hero layout="split" size="xl" class="invert-section">
    <Badge slot="badge" variant="brand" pill>For Business Owners Ready to Scale</Badge>
    <h1 slot="title">Ready to build your<br />growth engine?</h1>
    <p slot="description">
      Go into <strong class="text-foreground font-semibold">Growth Mode</strong> with an expert-led program, tutorials,
      templates and tech. Everything you need to scale revenue.
    </p>
    <Fragment slot="actions">
      <Button size="lg" href="#get-started" class="!h-14 !px-8 !text-base">
        Get Your Free Growth Plan
        <Icon name="arrow-right" size="sm" class="ml-2" />
      </Button>
    </Fragment>

    {/* Checklist below the CTA */}
    <ul class="mt-8 flex flex-col gap-2.5">
      {['10x your clarity on growth', '10x leads & conversion', '10x sales pipeline'].map((item) => (
        <li class="flex items-center gap-2 text-sm text-foreground-muted">
          <Icon name="check" size="sm" class="text-brand-500 shrink-0" />
          {item}
        </li>
      ))}
    </ul>
    <p class="mt-6 text-xs text-foreground-subtle">What 100s of businesses are using to scale growth</p>

    {/* Aside — placeholder for visual */}
    <div slot="aside" class="hidden lg:flex items-center justify-center rounded-xl border border-border bg-secondary aspect-[4/5] max-w-[360px] mx-auto">
      <p class="text-sm text-foreground-muted">Product visual</p>
    </div>
  </Hero>

  {/* ═══════════════════════════════════════════════════
      TRUST BAR
  ═══════════════════════════════════════════════════ */}
  <section class="py-10 border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <p class="text-center text-xs font-semibold uppercase tracking-widest text-foreground-muted mb-5">Trusted By</p>
      <div class="flex justify-center items-center gap-12 flex-wrap">
        {['Acme Corp', 'BrandCo', 'ScaleUp', 'GrowthHQ'].map((name) => (
          <span class="text-lg font-bold text-foreground-subtle">{name}</span>
        ))}
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      PROBLEM — Two-column
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)] bg-secondary">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <Card variant="default" padding="lg" class="flex justify-center items-center min-h-[240px]">
          <Icon name="alert-circle" class="w-24 h-24 text-brand-500" strokeWidth={1.5} />
        </Card>
        <div>
          <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
            Imagine going from current state to $10M+ per year FAST.
          </h2>
          <p class="mt-4 text-lg font-semibold text-foreground">What's stopping you?</p>
          <p class="mt-3 text-base leading-relaxed text-foreground-muted">
            You can unlock huge growth online. But without the tactics,
            systems and process, it's hard to know where to start — or how to
            drive real revenue.
          </p>
          <p class="mt-3 text-base leading-relaxed text-foreground-muted">
            Lots of ordinary people who run businesses like yours figure out
            how to make serious money. But how?!
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      AGITATE — "It's hard to know what works!"
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">The Problem</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">It's hard to know what works!</h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted max-w-2xl mx-auto">
          Figuring out how to really grow your business takes time, money, and the right
          people — and it's hard to make it happen, especially as fast as you want it to.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {[
          { title: 'A Trusted Brand', icon: 'globe' },
          { title: 'Lead Generation', icon: 'users' },
          { title: 'A Website That Sells', icon: 'layout' },
          { title: 'CRM & Pipeline', icon: 'layers' },
          { title: 'Landing Pages', icon: 'monitor' },
          { title: 'Marketing Automations', icon: 'settings' },
          { title: 'Sales Process', icon: 'trending-up' },
          { title: 'Conversion Rates', icon: 'zap' },
          { title: 'Integrations', icon: 'box' },
        ].map(({ title, icon }) => (
          <Card variant="default" padding="md" class="text-center">
            <Icon name={icon} class="w-10 h-10 mx-auto text-foreground-muted" strokeWidth={1.5} />
            <p class="mt-3 text-xs font-bold uppercase tracking-wide text-foreground">{title}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      SOLUTION — Letter-style offer
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">The Solution</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          We'll Build You The Foundation<br />You Need in Just 90 Days.
        </h2>
      </div>

      <Card variant="outline" padding="lg" class="max-w-2xl mx-auto pas-letter">
        <p><strong>Hey Business Owner,</strong></p>
        <p>We're not here to give you another "pretty website."</p>
        <p><strong>{siteConfig.name}</strong> delivers a full, sales-driven system, built by experts, to scale your business — fast.</p>
        <p>Most small business owners hit a ceiling. Your systems, brand, and website aren't just underperforming — they're <strong>costing you leads and sales</strong>.</p>
        <p>You know your online presence could unlock serious growth, but where do you even start?</p>

        <h3>The Promise...</h3>
        <p>With our program, you'll achieve more in 90 days than most businesses do in 12 months.</p>
        <p>We don't just build your website — we deliver a high-converting sales system, tailored to your goals, so you can:</p>
        <ol>
          <li>Stop losing leads to competitors</li>
          <li>Scale sales activity faster</li>
          <li>Hit $10K, $50K, $100K+ months</li>
        </ol>

        <h3>The Done-for-You Offer...</h3>
        <p>Here's how it works:</p>
        <ul>
          <li><strong>Done-for-You Website & Systems:</strong> We build and launch a professional, conversion-optimised website with CRM, lead funnels, payment pages, and more.</li>
          <li><strong>Sell-by-Chat Integration:</strong> Use SMS, WhatsApp, and email to close deals faster.</li>
          <li><strong>Custom Branding:</strong> Fully tailored to your business, using proven high-converting layouts.</li>
          <li><strong>Coaching & Setup Support:</strong> Beyond the tech, we guide you through sales strategies, automation, and lead generation tactics.</li>
          <li><strong>Continued Growth Tools:</strong> Monthly drops of new templates, walkthroughs, and SOPs to keep scaling.</li>
        </ul>

        <h3>The Result...</h3>
        <p>By the end of this project, you'll have:</p>
        <ul>
          <li>A system built to capture leads, drive sales, and build trust</li>
          <li>Confidence and clarity to grow your business online</li>
          <li>A strategic edge to outsell the competition</li>
        </ul>

        <p class="font-bold text-foreground !mt-6">So... stop guessing. Stop wasting time. And stop leaving money on the table.</p>

        <div class="mt-8 pt-6 border-t border-border">
          <Button size="lg" href="#get-started" fullWidth class="!h-14 !text-base">
            Get Your Free Growth Plan
            <Icon name="arrow-right" size="sm" class="ml-2" />
          </Button>
          <p class="text-center text-xs text-foreground-muted mt-2">See what's included, what it costs, and how to get started.</p>
        </div>
      </Card>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      DARK TRANSITION
  ═══════════════════════════════════════════════════ */}
  <CTA variant="invert" size="lg">
    <Badge slot="logo" variant="brand" pill>Done For You</Badge>
    <h2 slot="heading">Growth Mode</h2>
    <p slot="description">Your all-in-one solution to attract and convert clients, done-for-you and implemented in 90 days.</p>
  </CTA>

  {/* ═══════════════════════════════════════════════════
      OUTCOMES — Stats
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">The Outcomes We Drive</p>
          <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
            Supercharge Your Website & Landing Pages
          </h2>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <StatCard label="Your Brand" value="10x" icon="star" />
          <StatCard label="Conversion" value="10x" icon="trending-up" />
          <StatCard label="Easier to Manage" value="10x" icon="zap" />
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      SOCIAL PROOF — Testimonial
  ═══════════════════════════════════════════════════ */}
  <section class="invert-section py-[var(--space-section-lg)] bg-background">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-12 items-center">
        <div class="md:col-span-3">
          <svg class="w-10 h-10 text-foreground-subtle opacity-50" viewBox="0 0 24 24" fill="currentColor"><path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" /></svg>
          <p class="mt-4 text-2xl font-semibold leading-snug text-foreground">
            I was thinking about my brand, website and marketing channels
            completely wrong before I joined. The results have been incredible.
          </p>
          <div class="mt-6">
            <p class="text-sm font-bold text-foreground">Matthew LaValley</p>
            <p class="text-xs text-foreground-muted">Founder at Seven Figure Creators</p>
          </div>
        </div>
        <div class="md:col-span-2 grid grid-cols-2 gap-6">
          <div>
            <p class="text-5xl font-extrabold text-foreground">3x</p>
            <p class="mt-1 text-xs uppercase tracking-wider text-foreground-muted">Key hires from competition</p>
          </div>
          <div>
            <p class="text-5xl font-extrabold text-foreground">9x</p>
            <p class="mt-1 text-xs uppercase tracking-wider text-foreground-muted">High performing hires</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      HOW IT WORKS — Steps
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground text-center">How It Works</h2>
      <div class="max-w-xl mx-auto mt-[var(--space-section-header)] flex flex-col gap-8">
        {[
          { step: 'First', title: 'Book a Free Intro Chat', desc: 'See past results. And discover how we can help your business succeed.' },
          { step: 'Second', title: 'We Set You Up', desc: 'Get a ready-to-go 10x brand, website, and lead strategy.' },
          { step: 'Then', title: 'Use Our Platform', desc: 'Leverage B2B integrations and easy tools. Launch new strategies and boost conversions.' },
        ].map(({ step, title, desc }) => (
          <div class="flex gap-5 items-start">
            <div class="w-3 h-3 rounded-full bg-brand-500 shrink-0 mt-1.5" />
            <div>
              <p class="text-base text-foreground">{step}, <strong>{title}</strong></p>
              <p class="text-sm text-foreground-muted mt-1">{desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <Button size="lg" href="#get-started" variant="outline" class="!h-12 !px-8">
          Book a value-packed call
        </Button>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      INCLUSIONS
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)] bg-secondary">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground text-center">Offer Inclusions</h2>
      <div class="mt-[var(--space-section-header)] grid grid-cols-1 md:grid-cols-2">
        {[
          { title: 'Brand Research & SEO Analysis', desc: 'Deep-dive into your market, competitors, and keyword opportunities to position you for maximum visibility.' },
          { title: 'Web Design & Copywriting', desc: 'Craft beautiful, high-converting pages with copy that speaks directly to your buyer and drives action.' },
          { title: 'Strategy & Sitemap', desc: 'Map out your entire online presence with a clear structure built for conversions and growth.' },
          { title: 'CRM & Automation Setup', desc: 'Build and launch your complete CRM, lead funnels, payment pages, and sales automation workflows.' },
          { title: 'Sales Funnel Implementation', desc: 'High-converting landing pages, upsell flows, and complete funnel architecture built for your offer.' },
          { title: 'Development / Tech', desc: 'Production-grade code, integrations, and infrastructure built to scale with your business.' },
        ].map(({ title, desc }, i) => (
          <div class:list={[
            'py-6 md:p-6 border-b border-border',
            i % 2 === 0 && 'md:border-r'
          ]}>
            <h3 class="text-xs font-bold uppercase tracking-wide text-foreground">{title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-foreground-muted">{desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <p class="text-4xl font-extrabold text-foreground">$599</p>
        <Button size="md" href="#get-started" variant="link" class="mt-2">
          Get free sample chapters
          <Icon name="arrow-right" size="sm" class="ml-1" />
        </Button>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      BONUSES
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">But It Gets Better...</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">Because There's More!</h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted max-w-2xl mx-auto">
          We are strategists, designers and developers. Innovators and problem
          solvers. Small enough to be simple and quick.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { num: 'Bonus 1', title: 'Membership to Our Creator Community', desc: 'Get 1 Year of Membership including access to a community of creators, bi-weekly coaching calls, and course modules.' },
          { num: 'Bonus 2', title: 'Monthly Product Drops', desc: 'Get access to 12 Months of Monthly Product Drops, including high-converting page templates, plug-and-play strategies, and walkthroughs.' },
          { num: 'Bonus 3', title: 'Weekly Group Coaching', desc: 'Get 2 Weekly Group Coaching Sessions with on-demand tech help, strategy sessions, and expert guidance.' },
          { num: 'Bonus 4', title: 'Exclusive Growth Playbook Library', desc: 'Unlock our Exclusive Growth Playbook Library, featuring proven frameworks, ready-to-use scripts, and a curated collection of SOPs.' },
        ].map(({ num, title, desc }) => (
          <Card variant="default" padding="lg">
            <p class="text-xs font-bold uppercase tracking-wide text-brand-500">{num}</p>
            <h3 class="mt-1 text-lg font-bold text-foreground">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-foreground-muted">{desc}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      PRICING + GUARANTEE
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)] bg-secondary">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
        <div class="invert-section rounded-xl bg-background p-8">
          <p class="text-xs font-bold uppercase tracking-wide text-foreground-muted">Simple Pricing</p>
          <p class="mt-2 text-xl font-bold text-foreground leading-snug">One-time payment for full access. No payment plans — straightforward and simple.</p>
          <div class="mt-6 flex items-baseline gap-2">
            <span class="text-5xl font-extrabold text-foreground">$599</span>
            <span class="text-sm text-foreground-muted">per month</span>
          </div>
          <Button size="lg" href="#get-started" fullWidth class="mt-6 !h-12">
            Upgrade Now
          </Button>
        </div>
        <div>
          <h3 class="font-display text-2xl md:text-3xl font-bold tracking-tight text-foreground">Our Guarantee</h3>
          <p class="mt-4 text-base leading-relaxed text-foreground-muted">
            Here at {siteConfig.name} we focus on markets where technology,
            innovation, and capital can unlock long-term value. If you're not
            completely satisfied within the first 30 days, we'll work with you
            until you are — or give you a full refund. No questions asked.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      COMPARISON — With vs Without
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          Here's What Growth Looks Like<br />With vs. Without Growth Mode
        </h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted max-w-2xl mx-auto">Still wondering how big of a difference it makes? Let's break it down.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <Card variant="default" padding="lg">
          <h3 class="text-base font-bold text-foreground mb-4">With Growth Mode (The Smart Way)</h3>
          <ul class="flex flex-col gap-3">
            {[
              ['Strategic focus', 'A clear, proven roadmap built for scaling, so every move counts.'],
              ['Fast execution', 'Use plug-and-play systems to launch in days, not months.'],
              ['Guided support', 'Coaches and a community one message away when you need help.'],
              ['Cost-effective growth', 'One system covers it all, so every dollar drives real results.'],
              ['Clarity & momentum', 'Know exactly what to do next and see results as you go.'],
            ].map(([label, desc]) => (
              <li class="flex gap-3 text-sm text-foreground-muted">
                <div class="w-2 h-2 rounded-full bg-brand-500 shrink-0 mt-1.5" />
                <span><strong class="text-foreground">{label}</strong> — {desc}</span>
              </li>
            ))}
          </ul>
        </Card>
        <Card variant="solid" padding="lg">
          <h3 class="text-base font-bold text-foreground mb-4">Without Growth Mode (The Hard Way)</h3>
          <ul class="flex flex-col gap-3">
            {[
              ['Scattered efforts', 'Chasing tactics, testing random strategies, and hoping something sticks.'],
              ['Slow implementation', 'Trial-and-error, wasted months, and constantly starting from scratch.'],
              ['Going solo', 'No expert guidance, no feedback, no support when you hit a wall.'],
              ['High costs, low ROI', 'Spending on random tools, agencies, and freelancers, often with disappointing returns.'],
              ['Overwhelm & doubt', 'Always guessing, second-guessing, and feeling stuck.'],
            ].map(([label, desc]) => (
              <li class="flex gap-3 text-sm text-foreground-muted">
                <div class="w-2 h-2 rounded-full bg-[var(--error)] shrink-0 mt-1.5" />
                <span><strong class="text-foreground">{label}</strong> — {desc}</span>
              </li>
            ))}
          </ul>
        </Card>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      FAQ
  ═══════════════════════════════════════════════════ */}
  <section class="py-[var(--space-section-lg)] bg-secondary" id="faq">
    <div class="mx-auto max-w-3xl px-6">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground text-center mb-[var(--space-section-header)]">
        Frequently asked questions
      </h2>
      <Accordion items={faqItems} variant="default" size="md" exclusive />
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      FINAL CTA
