---
/**
 * Squeeze / Lead Magnet Page
 * Ultra-short single-screen optin. No nav, no distraction.
 * Headline, bullets, form, trust badge.
 */
import LeadLayout from '@/layouts/LeadLayout.astro';
import LeadCaptureForm from '@/components/forms/LeadCaptureForm.tsx';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

const formTags = ['funnel_blueprint', 'squeeze_page'];

const benefits = [
  'The exact $10K/mo funnel blueprint we use with clients',
  'Step-by-step setup guide — no tech skills needed',
  'Plug-and-play email sequences that convert',
];

const termsHtml = `<p>By providing my information, I agree to receive communications and accept the <a href="/terms">Privacy Policy</a>. Unsubscribe anytime.</p>`;
---

<LeadLayout
  title="Free: The $10K/mo Funnel Blueprint"
  description="Download the exact funnel blueprint we use to help businesses hit $10K+ months. Includes templates, sequences, and CRM setup guide."
>
  <section class="sq-hero relative overflow-hidden">
    <div
      class="bg-grid-pattern pointer-events-none absolute inset-0 [mask-image:linear-gradient(to_bottom,white,transparent)] opacity-40"
      aria-hidden="true"
    />

    <div class="mx-auto max-w-6xl px-6 relative z-10 py-6 md:py-0">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-[var(--space-section-gap)] items-center">

        {/* Left Column: Cover Image + Benefits */}
        <div class="hidden lg:block">
          <div class="overflow-hidden rounded-lg flex justify-center">
            <img src="/images/product-mockup.webp" alt="Funnel Blueprint preview" class="max-h-96 w-auto" loading="eager" />
          </div>
          <div class="mt-[var(--space-heading-gap)]">
            <h3 class="text-base font-bold text-foreground">What's inside</h3>
            <ul class="mt-4 space-y-3">
              {benefits.map((item) => (
                <li class="flex gap-3 items-start text-foreground-secondary text-sm">
                  <Icon name="check-circle" size="sm" class="text-brand-500 mt-0.5 shrink-0" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        {/* Right Column: Badge + Heading + Description + Form */}
        <div>
          <Badge variant="brand" pill>
            <Icon name="download" size="xs" />
            Free Download
          </Badge>

          <h1 class="mt-3 font-display text-2xl md:text-3xl font-bold tracking-tight text-foreground leading-tight">
            The $10K/mo Funnel Blueprint. Yours Free.
          </h1>

          <p class="mt-2 text-base leading-relaxed text-foreground-muted">
            Download the exact funnel we use to help businesses hit $10K+ months.
            Includes templates, email sequences, and CRM setup guide.
          </p>

          {/* Mobile image */}
          <div class="mt-4 lg:hidden">
            <div class="overflow-hidden rounded-lg">
              <img src="/images/product-mockup.webp" alt="Funnel Blueprint preview" class="w-full h-auto" loading="eager" />
            </div>
          </div>

          {/* Mobile benefits */}
          <ul class="mt-4 space-y-2 lg:hidden">
            {benefits.map((item) => (
              <li class="flex gap-2 items-start text-foreground-secondary text-sm">
                <Icon name="check-circle" size="sm" class="text-brand-500 mt-0.5 shrink-0" />
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <LeadCaptureForm
            client:load
            formTags={formTags}
            submitLabel="Get the Blueprint Free"
            termsHtml={termsHtml}
          />
        </div>

      </div>
    </div>
  </section>
</LeadLayout>

<style>
  .sq-hero {
    padding-top: calc(var(--space-page-top-sm) + 32px);
  }
  @media (min-width: 1024px) {
    .sq-hero {
      padding-top: calc(var(--space-page-top-sm) + 64px);
    }
  }
</style>
