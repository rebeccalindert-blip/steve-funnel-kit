---
/**
 * Demo-only: restores theme customizer settings from localStorage before paint.
 * Include in <head> of layouts. Delete when branding for production.
 */
---

<style is:inline>
  img[src*='logo'], img[src*='branding'] { filter: var(--sfk-logo-filter, none) !important; }
  h1, h2, h3, h4, h5, h6, .font-display {
    font-weight: var(--sfk-heading-weight, var(--theme-heading-weight, 700)) !important;
    text-transform: var(--sfk-heading-transform, none) !important;
  }
  button, [class*='rounded-full'][class*='font-medium'] {
    font-weight: var(--sfk-btn-weight, 500) !important;
    text-transform: var(--sfk-btn-transform, none) !important;
  }
</style>

<script is:inline>
  (function () {
    var PRESETS = {
      '0':    ['0','0','0','0','0','0'],
      '4px':  ['0.125rem','0.25rem','0.25rem','0.375rem','0.5rem','0.5rem'],
      '8px':  ['0.25rem','0.375rem','0.5rem','0.75rem','1rem','1rem'],
      '12px': ['0.375rem','0.5rem','0.75rem','1rem','1.5rem','9999px'],
      '16px': ['0.5rem','0.625rem','1rem','1.25rem','1.75rem','9999px'],
      '24px': ['0.75rem','1rem','1.5rem','2rem','2.5rem','9999px'],
    };
    var SERIF = ['DM Serif Display','Playfair Display','Fraunces','Libre Baskerville'];

    function fontStack(n) {
      return SERIF.indexOf(n) >= 0
        ? "'" + n + "', ui-serif, Georgia, serif"
        : "'" + n + "', ui-sans-serif, system-ui, sans-serif";
    }

    function restore() {
      var root = document.documentElement;

      var h = localStorage.getItem('sfk-hue');
      if (h) root.style.setProperty('--brand-hue', h);

      var rad = localStorage.getItem('sfk-radius');
      if (rad && PRESETS[rad]) {
        var sx = ['sm','md','lg','xl','2xl','full'];
        var vals = PRESETS[rad];
        for (var i = 0; i < sx.length; i++) {
          root.style.setProperty('--theme-radius-' + sx[i], vals[i]);
          root.style.setProperty('--radius-' + sx[i], vals[i]);
        }
      }

      var hf = localStorage.getItem('sfk-heading-font');
      if (hf) {
        var hs = fontStack(hf);
        root.style.setProperty('--font-display', hs);
        root.style.setProperty('--theme-font-display', hs);
      }

      var bf = localStorage.getItem('sfk-body-font');
      if (bf) {
        var bs = fontStack(bf);
        root.style.setProperty('--font-sans', bs);
        root.style.setProperty('--theme-font-sans', bs);
        root.style.fontFamily = bs;
      }

      // Heading weight + transform
      var hw = localStorage.getItem('sfk-heading-weight');
      if (hw) root.style.setProperty('--sfk-heading-weight', hw);
      var ht = localStorage.getItem('sfk-heading-uppercase');
      if (ht === '1') root.style.setProperty('--sfk-heading-transform', 'uppercase');

      // Button weight + transform
      var bw = localStorage.getItem('sfk-btn-weight');
      if (bw) root.style.setProperty('--sfk-btn-weight', bw);
      var bt = localStorage.getItem('sfk-btn-uppercase');
      if (bt === '1') root.style.setProperty('--sfk-btn-transform', 'uppercase');

      // Load Google Fonts
      var fonts = [hf, bf].filter(function (f) { return f && f !== 'Plus Jakarta Sans'; });
      if (fonts.length) {
        var fam = fonts.map(function (f) {
          return f.replace(/ /g, '+') + ':wght@400;500;600;700;800;900';
        }).join('&family=');
        var lnk = document.createElement('link');
        lnk.rel = 'stylesheet';
        lnk.href = 'https://fonts.googleapis.com/css2?family=' + fam + '&display=swap';
        document.head.appendChild(lnk);
      }

      // Logo hue rotation
      if (h && h !== '162') {
        root.style.setProperty('--sfk-logo-filter', 'hue-rotate(' + (Number(h) - 162) + 'deg)');
      }
    }

    restore();
    document.addEventListener('astro:after-swap', restore);
  })();
</script>
