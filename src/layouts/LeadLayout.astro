---
import '@/styles/global.css';
import SEO from '@/components/seo/SEO.astro';
import Logo from '@/components/ui/marketing/Logo/Logo.astro';
import Footer from '@/components/layout/Footer.astro';
import siteConfig from '@/config/site.config';
// Demo-only: theme customizer + restore. Only renders when PUBLIC_DEMO_MODE=true.
import ThemeCustomizer from '@/components/_demo/ThemeCustomizer.tsx';
import DemoRestore from '@/components/_demo/DemoRestore.astro';
const isDemo = import.meta.env.PUBLIC_DEMO_MODE === 'true';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href={siteConfig.branding.favicon.svg} />
    <meta name="theme-color" content={siteConfig.branding.colors.themeColor} />

    <SEO title={title} description={description} noindex={true} />

    <script is:inline>
      (function () {
        var mq = window.matchMedia('(prefers-color-scheme: dark)');
        function apply() {
          var sfkDark = localStorage.getItem('sfk-dark');
          if (sfkDark !== null) {
            document.documentElement.classList.toggle('dark', sfkDark === '1');
            return;
          }
          document.documentElement.classList.toggle('dark', mq.matches);
        }
        apply();
        mq.addEventListener('change', apply);
      })();
    </script>

    {isDemo && <DemoRestore />}
  </head>

  <body class="min-h-screen flex flex-col bg-background text-foreground antialiased">
    <header class="absolute top-0 left-0 right-0 z-50 py-6">
      <div class="mx-auto max-w-6xl px-6">
        <a href="/" aria-label={siteConfig.name}>
          <Logo variant="full" size="lg" />
        </a>
      </div>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <Footer
      layout="minimal"
      showCopyright
      legalLinks={[
        { label: 'Privacy', href: '/terms' },
      ]}
    />
    {isDemo && <ThemeCustomizer client:only="react" />}
  </body>
</html>

<style is:global>
  footer {
    border-top: none;
    padding: 0 0 1rem;
  }
</style>
